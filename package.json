{
  "name": "@keytd/client",
  "version": "0.1.0",
  "description": "Tiny, zero-dependency JavaScript client for the keytd data API.",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./src/index.js",
      "require": "./src/index.js"
    }
  },
  "files": [
    "src/",
    "index.d.ts",
    "README.md"
  ],
  "scripts": {
    "test": "node test/smoke.mjs"
  },
  "keywords": [
    "keytd",
    "headless-cms",
    "backend",
    "rest",
    "api-client",
    "sdk"
  ],
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  }
}
